{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/safe-bash.ts"
          },
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/steer-send.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/track-activity.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/track-activity.ts"
          },
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/check-discord-messages.ts"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/cleanup-attachment.ts"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/track-activity.ts"
          },
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/check-discord-messages.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/check-discord-messages.ts"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/track-activity.ts"
          },
          {
            "type": "command",
            "command": "__ORCHESTRATOR_DIR__/hooks/check-discord-messages.ts"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(send-discord:*)",
      "Bash(send-imessage:*)",
      "Bash(wait-for-discord-messages:*)"
    ]
  }
}
